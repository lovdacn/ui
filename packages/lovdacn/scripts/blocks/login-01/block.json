{
  "name": "login-01",
  "type": "registry:block",
  "description": "A sign-in screen: an (auth) route group with a login form card.",
  "dependencies": ["react-native-safe-area-context"],
  "registryDependencies": ["card", "input", "label", "button", "text", "utils"],
  "files": [
    {
      "src": "layout.tsx",
      "type": "registry:page",
      "target": "app/(auth)/_layout.tsx"
    },
    {
      "src": "sign-in.tsx",
      "type": "registry:page",
      "target": "app/(auth)/sign-in.tsx"
    },
    {
      "src": "components/login-form.tsx",
      "type": "registry:component",
      "path": "components/login-form.tsx"
    }
  ]
}
