{
  "name": "lovda",
  "type": "module",
  "version": "1.0.0",
  "private": false,
  "files": [
    "dist",
    "templates"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": "./dist/index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsup && node -e \"const fs=require('fs-extra'); fs.removeSync('./templates'); fs.copySync('../templates', './templates', {filter: (src) => !src.includes('node_modules') && !src.includes('.expo') && !src.includes('.git') && !src.includes('package-lock.json') && !src.includes('bun.lock') && !src.includes('styles')})\"",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist templates"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "rimraf": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "tsup": "^8.5.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "module": "src/index.ts"
}
